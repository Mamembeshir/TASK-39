NODE_ENV=development
SEED_FIXTURES=false
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/homecareops

JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

CORS_ALLOWLIST=http://localhost:5173,https://localhost:4000,https://localhost
MEDIA_UPLOAD_DIR=./data/uploads
MEDIA_ENABLE_PROCESSING=false
RETENTION_CLEANUP_SCHEDULER_ENABLED=true
RETENTION_CLEANUP_INTERVAL_MS=86400000
RETENTION_CLEANUP_DAYS=365

TLS_ENABLED=true
TLS_KEY_PATH=../certs/localhost.key
TLS_CERT_PATH=../certs/localhost.crt
TRUST_PROXY_HEADERS=false

INTERNAL_ROUTES_ENABLED=false
INTERNAL_ROUTES_TOKEN=replace-with-internal-shared-secret
